*.tfvars
*.tfvars.json
!*.example.tfvars

# Terraform crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terragrunt cache
**/.terragrunt-cache/

# Terratest
**/tests/terraform.tfvars

# Go test binaries and cache
**/*.test
**/vendor/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Local env files
.env
.env.*
